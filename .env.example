# PILO local development environment

NODE_ENV=development
APP_ENV=local
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# App URLs
# App server URLs are origins. Browser API clients append /api/v1.
FRONTEND_URL=http://localhost:3000
APP_SERVER_URL=http://localhost:4000
API_PUBLIC_ORIGIN=http://localhost:4000
REALTIME_SERVER_URL=http://localhost:4001
NEXT_PUBLIC_PILO_REALTIME_SERVER_URL=http://localhost:4001
AI_WORKER_URL=http://localhost:8000
NEXT_PUBLIC_PILO_APP_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_PILO_ENABLE_UI_PREVIEW=false

# Frontend client modes for MVP validation.
# Use auth=api with real OAuth secrets to validate authenticated MVP flows.
# auth=mock is only for local runs where OAuth client secrets are intentionally blank.
NEXT_PUBLIC_PILO_AUTH_MODE=mock
NEXT_PUBLIC_PILO_WORKSPACE_MODE=api
NEXT_PUBLIC_PILO_DASHBOARD_MODE=api
NEXT_PUBLIC_PILO_CANVAS_MODE=api
NEXT_PUBLIC_PILO_TASK_MODE=api
NEXT_PUBLIC_PILO_GITHUB_MODE=api
NEXT_PUBLIC_PILO_REVIEW_MODE=api
NEXT_PUBLIC_PILO_MEETING_MODE=api
NEXT_PUBLIC_PILO_VOICE_MODE=api
NEXT_PUBLIC_PILO_AGENT_MODE=api
NEXT_PUBLIC_PILO_NOTIFICATION_MODE=api
NEXT_PUBLIC_PILO_LOCAL_ACTOR_MODE=enabled

# SQLtoERD write protocol rollout
SQL_ERD_OPERATIONS_V1_ENABLED=false

# Agent execution handoff (AI Worker -> App Server internal endpoint)
AGENT_EXECUTION_HANDOFF_BASE_URL=http://localhost:4000
AGENT_EXECUTION_HANDOFF_TOKEN=change-me-local-agent-execution-handoff-token
AGENT_EXECUTION_HANDOFF_TIMEOUT_SECONDS=10
MEETING_REPORT_EVENT_BASE_URL=http://localhost:4000
MEETING_REPORT_EVENT_TOKEN=change-me-local-meeting-report-event-token
MEETING_REPORT_EVENT_TIMEOUT_SECONDS=10
MEETING_REPORT_EVENT_MAX_ATTEMPTS=3

# Database / Cache
DATABASE_URL=postgresql://pilo:pilo@localhost:5432/pilo
DATABASE_SSL=false
DATABASE_POOL_MAX=2
DATABASE_POOL_IDLE_TIMEOUT_MS=10000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
DATABASE_APPLICATION_NAME=pilo-app-server
REDIS_URL=redis://localhost:6379

# Local SQS via LocalStack
SQS_ENDPOINT=http://localhost:4566
# Canvas publisher and legacy Agent drain use the shared AI jobs queue.
SQS_AI_JOBS_QUEUE_URL=http://localhost:4566/000000000000/pilo-dev-ai-jobs
# Agent publisher and Agent worker use this dedicated queue.
SQS_AGENT_JOBS_QUEUE_URL=http://localhost:4566/000000000000/pilo-dev-agent-jobs
# MeetingReport publisher and Meeting worker use this dedicated queue.
SQS_MEETING_JOBS_QUEUE_URL=http://localhost:4566/000000000000/pilo-dev-meeting-jobs
SQS_GITHUB_WEBHOOKS_QUEUE_URL=http://localhost:4566/000000000000/pilo-dev-github-webhooks

# Local object storage placeholders.
# Use real S3 bucket names in deployed environments.
S3_UPLOADS_BUCKET=pilo-local-uploads
S3_RECORDINGS_BUCKET=pilo-local-uploads

# Auth
JWT_SECRET=change-me-local-jwt-secret
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=change-me-32-byte-local-key-only
GITHUB_LOGIN_CLIENT_ID=
GITHUB_LOGIN_CLIENT_SECRET=
GITHUB_USER_OAUTH_CLIENT_ID=
GITHUB_USER_OAUTH_CLIENT_SECRET=
GITHUB_PROJECT_OAUTH_CLIENT_ID=
GITHUB_PROJECT_OAUTH_CLIENT_SECRET=
SESSION_SECRET=change-me-local-session-secret
AUTH_SESSION_SECRET_VERSION=v1
AUTH_SESSION_TTL_SECONDS=604800
AUTH_SESSION_COOKIE_SECURE=false
OAUTH_STATE_TTL_SECONDS=600

# GitHub repository integration
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN_ENCRYPTION_KEY=change-me-32-byte-local-key-only

# LiveKit voice MVP
LIVEKIT_API_KEY=pilo_dev_key
LIVEKIT_API_SECRET=change-me-local-livekit-secret
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_RECORDING_MODE=room_audio_only
LIVEKIT_RECORDINGS_BUCKET=pilo-local-uploads
LIVEKIT_EGRESS_S3_PREFIX=recordings/meetings

# AI providers
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_MEETING_REPORT_MODEL=gpt-5.4-mini
OPENAI_MEETING_TRANSCRIPT_EMBEDDING_MODEL=text-embedding-3-small
