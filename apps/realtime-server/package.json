{
  "name": "@pilo/realtime-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format:check": "node scripts/check-format.mjs",
    "lint": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "npm run build && node scripts/test.mjs && node src/canvas/canvas-room-state-checkpoint.test.mjs && node src/canvas/recording-activity/canvas-recording-activity.test.mjs && npm run test:workspace-presence && npm run test:page-cursor-membership-revocation && npm run test:board-membership-revocation && npm run test:github-source-membership-revocation && npm run test:screen-share",
    "test:board-membership-revocation": "node src/board/board-membership-revocation.test.mjs",
    "test:github-source-membership-revocation": "node src/github-source/github-source-membership-revocation.test.mjs",
    "test:page-cursor-membership-revocation": "node src/page-cursor/page-cursor-membership-revocation.test.mjs",
    "test:screen-share": "npm run build && node --test src/screen-share/screen-share-fan-out.test.mjs src/screen-share/screen-share-subscription.test.mjs",
    "test:workspace-presence": "node src/workspace-presence/workspace-presence.service.test.mjs && node src/workspace-presence/workspace-presence-socket-lifecycle.test.mjs"
  },
  "dependencies": {
    "@hocuspocus/server": "^4.4.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tldraw/sync-core": "^5.1.1",
    "@types/pg": "^8.20.0",
    "crossws": "^0.4.10",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "socket.io": "^4.8.3",
    "ws": "^8.21.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "socket.io-client": "^4.8.3",
    "typescript": "^6.0.3"
  }
}
