project_name = "pilo"
environment  = "dev"
aws_region   = "ap-northeast-2"

# Fill these when Route53 is ready.
create_dns_records    = false
domain_name           = "pilo.example.com"
frontend_domain_name  = "dev.pilo.example.com"
api_domain_name       = "api.dev.pilo.example.com"
hosted_zone_id        = ""

# Dev keeps NAT disabled. ECS tasks run in public subnets with public IPs.
enable_nat_gateway    = false
ecs_assign_public_ip  = true

github_owner = "Developer-EJ"
github_repo  = "PILO"

# Dev images are available in ECR, so each service runs one task by default.
app_server_desired_count            = 1
realtime_server_desired_count       = 1
ai_worker_desired_count             = 1
meeting_worker_desired_count        = 1
pr_review_ai_worker_desired_count   = 1

# Self-hosted LiveKit MVP host. Keep public CIDRs open for WebRTC unless a
# stricter access policy is ready.
livekit_instance_type        = "t3.small"
livekit_ami_id               = "ami-0123456789abcdef0"
livekit_root_volume_size     = 30
livekit_allowed_cidr_blocks  = ["0.0.0.0/0"]
